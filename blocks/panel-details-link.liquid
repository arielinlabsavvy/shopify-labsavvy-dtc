{%- liquid
  assign product_resource = closest.product | default: product
  assign proxy_path = block.settings.proxy_path | strip
  if proxy_path == blank
    assign proxy_path = '/tools/panels'
  endif
  # Absolute URL: themes with <base href> break relative fetch('/tools/panels')
  assign proxy_fetch_url = request.origin | append: proxy_path
-%}

{% if product_resource %}
  <rte-formatter
    class="spacing-style text-block rte text-block--align-left labsavvy-panel-details-root"
    style="
      {% render 'spacing-padding', settings: block.settings %}
      --width: 100%;
      --max-width: var(--max-width--body-normal);
      --text-align: left;
    "
    {{ block.shopify_attributes }}
  >
    <div
      id="labsavvy-panels-{{ block.id }}"
      class="labsavvy-panel-details"
      data-labsavvy-panel-details
      data-proxy-path="{{ proxy_path | escape }}"
      data-proxy-url="{{ proxy_fetch_url | escape }}"
      data-product-id="{{ product_resource.id }}"
      data-heading="{{ block.settings.link_label | escape }}"
    >
      <p class="labsavvy-panel-details__status" data-role="status" aria-live="polite">
        {{- block.settings.loading_text -}}
      </p>
      <div class="labsavvy-panel-details__content" data-role="content" hidden></div>
    </div>
  </rte-formatter>
  <script>
    (function () {
      var root = document.getElementById('labsavvy-panels-{{ block.id }}')
      if (!root) return

      function escapeHtml(s) {
        return String(s)
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;')
      }

      var proxyUrl = root.getAttribute('data-proxy-url')
      var proxyPath = root.getAttribute('data-proxy-path') || '/tools/panels'
      var productId = root.getAttribute('data-product-id')
      var heading = root.getAttribute('data-heading') || 'Panel details'
      var statusEl = root.querySelector('[data-role="status"]')
      var contentEl = root.querySelector('[data-role="content"]')

      if (!productId) {
        if (statusEl) statusEl.textContent = 'Missing product.'
        return
      }

      var qs = 'product_id=' + encodeURIComponent(productId)
      var base = proxyUrl || (typeof window !== 'undefined' ? window.location.origin + proxyPath : proxyPath)
      var url = base + (base.indexOf('?') >= 0 ? '&' : '?') + qs

      function bodyPreview(t, maxLen) {
        var s = String(t || '').replace(/\s+/g, ' ').trim()
        if (s.length > maxLen) s = s.slice(0, maxLen) + '…'
        return s
      }

      function parseLabsavvyResponse(r, text) {
        var trimmed = String(text || '').replace(/^\uFEFF/, '').trim()
        var ct = (r.headers && r.headers.get && r.headers.get('content-type')) || ''

        if (!r.ok) {
          var errMsg = 'HTTP ' + r.status
          try {
            var errBody = JSON.parse(trimmed)
            if (errBody.reason) errMsg += ' (' + errBody.reason + ')'
            else if (errBody.error) errMsg += ': ' + errBody.error
          } catch (e) {
            if (trimmed.indexOf('<!DOCTYPE') !== -1 || trimmed.indexOf('<html') !== -1) {
              errMsg += ' — response is HTML, not JSON (often means the request never reached LabSavvy).'
            } else if (trimmed) {
              errMsg += ' — ' + bodyPreview(trimmed, 100)
            }
          }
          throw new Error(errMsg)
        }

        if (!trimmed) {
          throw new Error(
            'HTTP ' +
              r.status +
              ' with empty body. The app proxy may not be forwarding to LabSavvy, or the API returned nothing.',
          )
        }

        try {
          return JSON.parse(trimmed)
        } catch (e) {
          var looksHtml =
            trimmed.indexOf('<!DOCTYPE') !== -1 ||
            trimmed.indexOf('<html') !== -1 ||
            trimmed.indexOf('<HTML') !== -1
          throw new Error(
            'HTTP ' +
              r.status +
              ' but body is not JSON' +
              (ct ? ' (Content-Type: ' + bodyPreview(ct, 60) + ')' : '') +
              (looksHtml
                ? '. Shopify returned HTML — usually the storefront path is not the app proxy (check theme App proxy path vs Settings → Apps → your app → App proxy), or the proxy URL still points at the wrong host.'
                : '. Preview: ' + bodyPreview(trimmed, 120)),
          )
        }
      }

      fetch(url, { credentials: 'same-origin', headers: { Accept: 'application/json' } })
        .then(function (r) {
          return r.text().then(function (text) {
            return parseLabsavvyResponse(r, text)
          })
        })
        .then(function (data) {
          if (statusEl) statusEl.hidden = true
          if (!contentEl) return
          var panels = data.panels || []
          var productName = data.productName || ''
          var html = ''
          html += '<h3 class="labsavvy-panel-details__heading">' + escapeHtml(heading) + '</h3>'
          if (productName) {
            html += '<p class="labsavvy-panel-details__product">' + escapeHtml(productName) + '</p>'
          }
          if (!panels.length) {
            html += '<p class="labsavvy-panel-details__empty">No panel information for this product.</p>'
          } else {
            html += '<ul class="labsavvy-panel-details__list">'
            for (var i = 0; i < panels.length; i++) {
              var p = panels[i] || {}
              var code = p.code != null ? String(p.code) : ''
              var name = p.name != null ? String(p.name) : ''
              var line = name ? name + ' (' + code + ')' : code
              html += '<li>' + escapeHtml(line) + '</li>'
            }
            html += '</ul>'
          }
          contentEl.innerHTML = html
          contentEl.hidden = false
        })
        .catch(function (err) {
          if (statusEl) {
            var msg = err && err.message ? err.message : 'Request failed'
            var hints = []
            if (msg.indexOf('HTTP 403') !== -1 && msg.indexOf('bad_signature') !== -1) {
              hints.push(
                'bad_signature: set api SHOPIFY_API_SECRET to the same value as the app Client secret in Dev Dashboard.',
              )
            }
            if (msg.indexOf('HTTP 403') !== -1 && msg.indexOf('shop_mismatch') !== -1) {
              hints.push(
                'shop_mismatch: set SHOPIFY_SHOP_DOMAIN to your store’s …myshopify.com hostname.',
              )
            }
            if (msg.indexOf('not JSON') !== -1 || msg.indexOf('HTML') !== -1) {
              hints.push(
                'App proxy destination must be your public LabSavvy API base ending in /tools (not the myshopify.com storefront URL).',
              )
            }
            if (msg.indexOf('Failed to fetch') !== -1 || msg.indexOf('NetworkError') !== -1) {
              hints.push('Network error — check browser devtools Network tab for the request URL and status.')
            }
            var extra = hints.length ? ' — ' + hints.join(' ') : ''
            statusEl.textContent = msg + extra
            statusEl.hidden = false
          }
        })
    })()
  </script>
{% endif %}

{% schema %}
{
  "name": "Panel details (LabSavvy)",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "link_label",
      "label": "Heading",
      "default": "Panel details"
    },
    {
      "type": "text",
      "id": "proxy_path",
      "label": "App proxy path (storefront)",
      "default": "/tools/panels",
      "info": "Must match your Shopify app proxy (default: prefix tools, subpath panels → /tools/panels). Uses ?product_id=…; Shopify adds signature when proxying to LabSavvy."
    },
    {
      "type": "text",
      "id": "loading_text",
      "label": "Loading text",
      "default": "Loading panel details…"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "Left",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "Right",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ]
}
{% endschema %}
